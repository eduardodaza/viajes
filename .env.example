# ============================================================
#  TripCraft AI — Variables de Entorno
#  Copia este archivo como .env.local para desarrollo local
#  En Vercel: Settings > Environment Variables
# ============================================================

# ── OBLIGATORIA ─────────────────────────────────────────────
# Anthropic — Motor principal de IA para generar itinerarios
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── OPCIONALES (mejoran la calidad de datos) ─────────────────

# Google Places API — restaurantes, ratings, fotos, horarios
# Obtén tu key en: https://console.cloud.google.com/
# Activa: Places API, Maps JavaScript API, Geocoding API
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenWeather — clima actual y pronóstico 7 días
# Obtén tu key en: https://openweathermap.org/api (plan gratuito)
OPENWEATHER_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Ticketmaster / Discovery API — eventos, conciertos, festivales
# Obtén tu key en: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Foursquare Places API — segunda fuente de restaurantes y ratings
# Obtén tu key en: https://foursquare.com/developers/
FOURSQUARE_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Amadeus Travel API — precios de vuelos y hoteles (plan de prueba gratis)
# Obtén tu key en: https://developers.amadeus.com/
AMADEUS_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AMADEUS_CLIENT_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Booking.com Affiliate API — disponibilidad y precios de hoteles
# Registro en: https://www.booking.com/affiliate-program/
BOOKING_AFFILIATE_ID=XXXXXXXX
BOOKING_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe — pagos y reservas (fase Alpha)
# Obtén tu key en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── CONFIGURACIÓN INTERNA ────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TripCraft AI

# Idioma por defecto (es | en | fr | de | pt | it)
NEXT_PUBLIC_DEFAULT_LOCALE=es
